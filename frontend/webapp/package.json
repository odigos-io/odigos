{
  "name": "webapp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "check-peer-dependencies --runOnlyOnRootDependencies",
    "dev": "next dev --turbopack",
    "prebuild": "rm -rf out .next",
    "build": "next build --turbopack",
    "build:analyze": "ANALYZE=true next build --turbopack",
    "postbuild": "mkdir -p out && touch out/.keep",
    "back:build": "cd .. && go build -o odigos-backend",
    "back:start": "cd .. && ./odigos-backend --port 8085 --debug --address 0.0.0.0",
    "lint": "next lint",
    "lint:fix": "next lint --fix"
  },
  "dependencies": {
    "@apollo/client": "^4.2.6",
    "@odigos/ui-kit": "0.0.268",
    "graphql": "^16.14.2",
    "next": "15.5.18",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-error-boundary": "^6.1.2",
    "rxjs": "^7.8.1",
    "styled-components": "6.3.12",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.10",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "^10.5.2",
    "check-peer-dependencies": "^4.3.4",
    "eslint": "9.39.2",
    "eslint-config-next": "16.2.10",
    "postcss": "^8.5.18",
    "typescript": "5.9.3"
  }
}
