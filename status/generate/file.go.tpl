// {{ .TypeName }}ReasonByName returns the status.Reason for a reason string, or false if unknown.
func {{ .TypeName }}ReasonByName(reason string) (status.Reason, bool) {
	r, ok := {{ .TypeName }}ByReason[reason]
	return r, ok
}
