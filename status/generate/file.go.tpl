{{- end }}
)

const (
	{{ .TypeName }}Type = {{ printf "%q" .TypeName }}
{{- if .OwnerResource }}
	{{ .TypeName }}OwnerResource = {{ printf "%q" .OwnerResource }}
{{- end }}
{{- if .Scope }}
