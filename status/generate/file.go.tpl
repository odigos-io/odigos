{{- end }}
)

var (
{{- range .Reasons }}
	{{ $.TypeName }}{{ .Name }} = status.WithMessageTemplate(status.Reason{
		Name: string({{ $.TypeName }}Reason{{ .Name }}),
{{- if .Title }}
		Title: {{ printf "%q" .Title }},
{{- end }}
{{- if .Summary }}
		Summary: {{ printf "%q" .Summary }},
{{- end }}
{{- if .Description }}
		Description: {{ printf "%q" .Description }},
{{- end }}
{{- if .Message }}
